{
    "manifest_version": 3,
    "name": "Instagram Session ID Extractor",
    "description": "Extract and copy your Instagram session ID",
    "version": "1.0.0",
    "permissions": [
        "cookies"
    ],
    "host_permissions": [
        "https://www.instagram.com/*"
    ],
    "icons": {
        "16": "icon-16.png",
        "32": "icon-32.png",
        "48": "icon-48.png",
        "128": "icon-128.png"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "Instagram Session ID Extractor",
        "default_icon": {
            "16": "icon-16.png",
            "32": "icon-32.png",
            "48": "icon-48.png"
        }
    }
}
